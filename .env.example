# Copy to .env and keep the real values private. Never commit .env.
PERSISTENT_LINKS_ENABLED=true
LINK_DATABASE_PATH=/var/data/subscriptions.sqlite3
LINK_SECRET_KEY=REPLACE_WITH_URLSAFE_BASE64_FOR_32_RANDOM_BYTES
PUBLIC_BASE_URL=https://converter.example.com
MAX_ACTIVE_LINKS=100
MAX_LINKS_PER_SOURCE=3
MAX_LINKS_PER_USER=3
MAX_LINKS_PER_NETWORK=10

# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# Open /admin/enroll in the one browser profile you trust, enroll it, then
# remove this variable and redeploy. Never paste this value into a URL.
ADMIN_BOOTSTRAP_SECRET=REPLACE_WITH_ONE_TIME_URLSAFE_RANDOM_TOKEN

# Set only when a trusted reverse proxy supplies/overwrites this header.
# Render deployments should use X-Forwarded-For.
TRUSTED_CLIENT_IP_HEADER=X-Forwarded-For

# Short-lived in-process abuse limits. Durable quotas above remain atomic.
CHECK_RATE_LIMIT=30
CHECK_RATE_WINDOW_SECONDS=60
CREATE_RATE_LIMIT=5
CREATE_RATE_WINDOW_SECONDS=3600
CLOSE_RATE_LIMIT=20
CLOSE_RATE_WINDOW_SECONDS=60

# Keep false for new deployments. Enable only during a controlled migration of
# existing raw ?url= clients to opaque /s/<token> links.
ALLOW_LEGACY_URL_ENDPOINTS=false
